# Runtime
NODE_ENV=development
PORT=3000

# Required
DATABASE_URL=postgresql://username:password@host:5432/database
JWT_SECRET=replace-with-a-strong-random-string

# Optional (required only if using hero video upload)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token

# Optional bootstrap admin account.
# To auto-create an admin user during initial seed, set both ADMIN_CREDENTIAL and ADMIN_PASSWORD.
ADMIN_CREDENTIAL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_NAME=Moto Admin
