# Environment Variables - Copy to .env and fill with your values

# Server Configuration
NODE_ENV=production
PORT=3000

# JWT Authentication Secret
# IMPORTANT: Change this to a strong random string in production
JWT_SECRET=your-very-secure-secret-key-change-this

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Backend URL
BACKEND_URL=http://localhost:3000

# Database Configuration (optional - for future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/moto_cooperation

# Email Configuration (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# EmailJS (optional - for contact form)
# EMAILJS_SERVICE_ID=service_xxxxx
# EMAILJS_TEMPLATE_ID=template_xxxxx
# EMAILJS_PUBLIC_KEY=public_key_xxxxx

# Razorpay (optional - for payments)
# RAZORPAY_KEY_ID=rzp_xxxxx
# RAZORPAY_KEY_SECRET=xxxxx

# AWS S3 (optional - for file uploads)
# AWS_ACCESS_KEY_ID=xxxxx
# AWS_SECRET_ACCESS_KEY=xxxxx
# AWS_REGION=ap-south-1
# AWS_BUCKET_NAME=moto-cooperation
