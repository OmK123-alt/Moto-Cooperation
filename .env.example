# Runtime
NODE_ENV=development
PORT=3000

# Required for PostgreSQL persistence
DATABASE_URL=postgresql://username:password@host:5432/database

# Required for JWT auth
JWT_SECRET=replace-with-a-strong-random-string

# Required for hero video upload via Vercel Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token

# Optional bootstrap admin account (created on first seed if missing)
ADMIN_CREDENTIAL=admin
ADMIN_PASSWORD=moto2024
ADMIN_NAME=Moto Admin
