{
  "version": 2,
  "buildCommand": "echo build-complete",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/(.*)", "destination": "/admin/index.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "functions": {
    "api/[...path].js": {
      "includeFiles": "backend/data/**"
    }
  }
}
